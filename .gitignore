# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore SQLite databases
/db/*.sqlite3
/db/*.sqlite3-journal

# Ignore local scripts
/db/standalone_update.rb

# Knowledge Base (실제 문서는 제외, README와 폴더 구조는 포함)
/knowledge-base/*
!/knowledge-base/.gitkeep
!/knowledge-base/README.md
!/knowledge-base/rfp-samples/
!/knowledge-base/previous-proposals/
!/knowledge-base/templates/
!/knowledge-base/resources/
/knowledge-base/rfp-samples/*
!/knowledge-base/rfp-samples/.gitkeep
/knowledge-base/previous-proposals/*
!/knowledge-base/previous-proposals/.gitkeep
/knowledge-base/templates/*
!/knowledge-base/templates/.gitkeep
/knowledge-base/resources/*
!/knowledge-base/resources/.gitkeep

# Expo mobile app
mobile/node_modules/
mobile/dist/
mobile/.expo/
