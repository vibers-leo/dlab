<div class="company-templates-page">
  <div class="header">
    <h1>회사 템플릿 관리</h1>
    <%= link_to "새 템플릿 추가", new_admin_company_template_path, class: "btn btn-primary" %>
  </div>

  <p class="description">
    입찰 제안서에 반복적으로 사용되는 회사 소개, 연혁, 조직도 등을 템플릿으로 관리합니다.<br>
    템플릿을 활성화하면 슬라이드 생성 시 자동으로 삽입됩니다.
  </p>

  <% @template_types.each do |type_key, type_name| %>
    <% templates = @company_templates.by_type(type_key) %>
    <% if templates.any? %>
      <div class="template-group">
        <h2><%= type_name %> (<%= templates.count %>개)</h2>
        <div class="template-grid">
          <% templates.each do |template| %>
            <div class="template-card <%= template.active ? '' : 'inactive' %>">
              <div class="template-header">
                <div class="template-badge <%= template.active ? 'active' : 'inactive' %>">
                  <%= template.active ? '활성' : '비활성' %>
                </div>
                <div class="template-order">순서: <%= template.order %></div>
              </div>
              <h3><%= template.name %></h3>
              <div class="template-preview">
                <%= truncate(template.content.presence || '내용 없음', length: 150) %>
              </div>
              <div class="template-actions">
                <%= link_to "수정", edit_admin_company_template_path(template), class: "btn btn-sm btn-outline" %>
                <%= button_to template.active ? "비활성화" : "활성화",
                    toggle_active_admin_company_template_path(template),
                    method: :patch,
                    class: "btn btn-sm #{template.active ? 'btn-warning' : 'btn-success'}" %>
                <%= button_to "삭제", admin_company_template_path(template),
                    method: :delete,
                    data: { confirm: "정말 삭제하시겠습니까?" },
                    class: "btn btn-sm btn-danger" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <% if @company_templates.empty? %>
    <div class="empty-state">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <path d="M3 9h18M9 21V9"/>
      </svg>
      <h3>등록된 템플릿이 없습니다</h3>
      <p>첫 번째 회사 템플릿을 추가해보세요</p>
      <%= link_to "템플릿 추가", new_admin_company_template_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<style>
  .company-templates-page {
    max-width: 1200px;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .header h1 {
    font-size: 1.875rem;
    font-weight: 700;
    color: #1E3A8A;
    margin: 0;
  }

  .description {
    color: #6B7280;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .template-group {
    margin-bottom: 3rem;
  }

  .template-group h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1E40AF;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #E5E7EB;
  }

  .template-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
  }

  .template-card {
    background: white;
    border: 2px solid #E5E7EB;
    border-radius: 0.5rem;
    padding: 1.5rem;
    transition: all 0.2s;
  }

  .template-card:hover {
    border-color: #1E40AF;
    box-shadow: 0 4px 12px rgba(30, 64, 175, 0.1);
  }

  .template-card.inactive {
    opacity: 0.6;
    background: #F9FAFB;
  }

  .template-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .template-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .template-badge.active {
    background: #D1FAE5;
    color: #065F46;
  }

  .template-badge.inactive {
    background: #F3F4F6;
    color: #6B7280;
  }

  .template-order {
    font-size: 0.875rem;
    color: #9CA3AF;
  }

  .template-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #111827;
    margin-bottom: 0.75rem;
  }

  .template-preview {
    color: #6B7280;
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    min-height: 60px;
  }

  .template-actions {
    display: flex;
    gap: 0.5rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: white;
    border-radius: 0.5rem;
    border: 2px dashed #E5E7EB;
  }

  .empty-state svg {
    color: #9CA3AF;
    margin: 0 auto 1rem;
  }

  .empty-state h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: #6B7280;
    margin-bottom: 1.5rem;
  }

  .btn {
    padding: 0.625rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    text-decoration: none;
    font-size: 0.875rem;
    display: inline-block;
  }

  .btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
  }

  .btn-primary {
    background: #1E3A8A;
    color: white;
  }

  .btn-primary:hover {
    background: #3B82F6;
  }

  .btn-outline {
    background: white;
    color: #1E40AF;
    border: 2px solid #1E40AF;
  }

  .btn-outline:hover {
    background: #1E40AF;
    color: white;
  }

  .btn-success {
    background: #10B981;
    color: white;
  }

  .btn-success:hover {
    background: #059669;
  }

  .btn-warning {
    background: #F59E0B;
    color: white;
  }

  .btn-warning:hover {
    background: #D97706;
  }

  .btn-danger {
    background: #DC2626;
    color: white;
  }

  .btn-danger:hover {
    background: #B91C1C;
  }
</style>
