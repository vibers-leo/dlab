<div class="company-template-edit">
  <div class="header">
    <h1>템플릿 수정: <%= @company_template.name %></h1>
    <%= link_to "← 목록으로", admin_company_templates_path, class: "btn btn-secondary" %>
  </div>

  <%= render 'form', company_template: @company_template %>
</div>

<style>
  .company-template-edit {
    max-width: 1000px;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .header h1 {
    font-size: 1.875rem;
    font-weight: 700;
    color: #1E3A8A;
    margin: 0;
  }

  .btn-secondary {
    padding: 0.625rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 500;
    background: #E5E7EB;
    color: #374151;
    text-decoration: none;
    font-size: 0.875rem;
  }

  .btn-secondary:hover {
    background: #D1D5DB;
  }
</style>
