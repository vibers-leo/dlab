<div class="biddings-admin">
  <div class="header">
    <div class="header-content">
      <h1>2026년 입찰&공모사업 현황</h1>
      <p class="subtitle">협력사: 리멘(Limen)</p>
    </div>
    <%= link_to "신규 등록", new_admin_bidding_path, class: "btn btn-primary" %>
  </div>

  <!-- Stats Cards -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-label">전체</div>
      <div class="stat-value"><%= @stats[:total] %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">예정</div>
      <div class="stat-value"><%= @stats[:scheduled] %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">진행중</div>
      <div class="stat-value"><%= @stats[:in_progress] %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">제출완료</div>
      <div class="stat-value"><%= @stats[:submitted] %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">선정</div>
      <div class="stat-value text-success"><%= @stats[:selected] %></div>
    </div>
  </div>

  <!-- Status Filter -->
  <div class="filter-bar">
    <%= link_to "전체", admin_biddings_path, class: "filter-btn #{'active' unless params[:status]}" %>
    <% Bidding.status_options.each do |status| %>
      <%= link_to status, admin_biddings_path(status: status), class: "filter-btn #{'active' if params[:status] == status}" %>
    <% end %>
  </div>

  <!-- Biddings Table -->
  <div class="biddings-table">
    <table class="table">
      <thead>
        <tr>
          <th>사업명</th>
          <th>공모기관</th>
          <th>신청기간</th>
          <th>예산규모</th>
          <th>상태</th>
          <th>진행률</th>
          <th>담당자</th>
          <th>액션</th>
        </tr>
      </thead>
      <tbody>
        <% @biddings.each do |bidding| %>
          <tr>
            <td class="title-cell">
              <%= link_to bidding.title, admin_bidding_path(bidding) %>
            </td>
            <td><%= bidding.agency %></td>
            <td class="text-sm"><%= bidding.application_period %></td>
            <td class="text-bold"><%= bidding.budget %></td>
            <td>
              <span class="badge badge-<%= bidding.status_color %>">
                <%= bidding.status %>
              </span>
            </td>
            <td>
              <div class="progress-container">
                <div class="progress-bar">
                  <div class="progress-fill progress-<%= bidding.progress_color %>" style="width: <%= bidding.progress %>%"></div>
                </div>
                <span class="progress-text"><%= bidding.progress %>%</span>
              </div>
            </td>
            <td><%= bidding.assignee %></td>
            <td>
              <%= link_to "수정", edit_admin_bidding_path(bidding), class: "btn-sm" %>
              <%= link_to "삭제", admin_bidding_path(bidding), method: :delete, data: { confirm: "정말 삭제하시겠습니까?" }, class: "btn-sm btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<style>
  .biddings-admin {
    --primary-blue: #1E3A8A;
    --primary-light: #3B82F6;
    --bg-gray: #F9FAFB;
    --border-gray: #E5E7EB;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .header h1 {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--primary-blue);
    margin: 0;
  }

  .subtitle {
    color: #6B7280;
    margin-top: 0.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: white;
    border: 1px solid var(--border-gray);
    border-radius: 0.5rem;
    padding: 1.5rem;
    text-align: center;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #6B7280;
    margin-bottom: 0.5rem;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary-blue);
  }

  .stat-value.text-success {
    color: #10B981;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-gray);
    border-radius: 0.375rem;
    background: white;
    color: #374151;
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    background: var(--bg-gray);
  }

  .filter-btn.active {
    background: var(--primary-blue);
    color: white;
    border-color: var(--primary-blue);
  }

  .biddings-table {
    background: white;
    border: 1px solid var(--border-gray);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .table {
    width: 100%;
    border-collapse: collapse;
  }

  .table thead {
    background: var(--bg-gray);
  }

  .table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: #6B7280;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border-gray);
  }

  .table td {
    padding: 1rem;
    border-bottom: 1px solid var(--border-gray);
  }

  .table tbody tr:hover {
    background: var(--bg-gray);
  }

  .title-cell a {
    color: var(--primary-blue);
    font-weight: 500;
    text-decoration: none;
  }

  .title-cell a:hover {
    text-decoration: underline;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .badge-gray { background: #F3F4F6; color: #374151; }
  .badge-blue { background: #DBEAFE; color: #1E40AF; }
  .badge-yellow { background: #FEF3C7; color: #92400E; }
  .badge-purple { background: #EDE9FE; color: #5B21B6; }
  .badge-green { background: #D1FAE5; color: #065F46; }
  .badge-red { background: #FEE2E2; color: #991B1B; }

  .progress-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .progress-bar {
    flex: 1;
    height: 0.5rem;
    background: #E5E7EB;
    border-radius: 9999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    transition: width 0.3s;
  }

  .progress-red { background: #EF4444; }
  .progress-yellow { background: #F59E0B; }
  .progress-blue { background: #3B82F6; }
  .progress-green { background: #10B981; }

  .progress-text {
    font-size: 0.75rem;
    color: #6B7280;
    min-width: 3rem;
    text-align: right;
  }

  .btn-primary {
    background: var(--primary-blue);
    color: white;
    padding: 0.625rem 1.25rem;
    border-radius: 0.375rem;
    text-decoration: none;
    font-weight: 500;
    border: none;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: var(--primary-light);
  }

  .btn-sm {
    padding: 0.375rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    text-decoration: none;
    background: white;
    border: 1px solid var(--border-gray);
    color: #374151;
  }

  .btn-sm:hover {
    background: var(--bg-gray);
  }

  .btn-danger {
    color: #DC2626;
    border-color: #DC2626;
  }

  .btn-danger:hover {
    background: #FEE2E2;
  }

  .text-sm {
    font-size: 0.875rem;
    color: #6B7280;
  }

  .text-bold {
    font-weight: 600;
  }
</style>
